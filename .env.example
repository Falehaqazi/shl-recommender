# OpenRouter is PRIMARY. Free tier gives access to Llama 3.3 70B
# (~20 RPM, 50 req/day without top-up).
# Get a key at https://openrouter.ai/keys (free, no card required).
OPENROUTER_API_KEY=

# Groq is fallback 1. Heavy free-tier limits, so used only when
# OpenRouter is rate-limited.
GROQ_API_KEY=

# Gemini is fallback 2. Optional. Many free-tier Google accounts
# have a 0-quota free tier (region restriction), so don't rely on it.
GEMINI_API_KEY=

# Model selection. The :free suffix on OpenRouter routes to free pool.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
PRIMARY_MODEL=llama-3.3-70b-versatile
FALLBACK_MODEL=gemini-2.0-flash

# Tuning knobs (defaults work; only override for experiments).
# LLM_TIMEOUT=12
# RETRIEVAL_TOP_K=30
# FINAL_TOP_K=10
# MAX_CLARIFICATIONS=2
# CATALOG_PATH=data/catalog.json
